# Application
NODE_ENV=development
PORT=3001
API_VERSION=v1

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=check12_dev
DB_USER=check12
DB_PASSWORD=check12password
DB_SSL=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Idempotency
IDEMPOTENCY_TTL_SECONDS=86400

# Mock integrations
SMILE_ID_DELAY_MS=3000
MOBILE_MONEY_DELAY_MS=3000
ORACLE_RATE_AFRI_XGHS=16.5

# Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# CORS
CORS_ORIGINS=http://localhost:3000

# Admin
ADMIN_EMAIL=admin@check12.com
ADMIN_PASSWORD=Admin@check12!

# API Key signing
API_KEY_SECRET=your-api-key-hmac-secret-change-in-production
